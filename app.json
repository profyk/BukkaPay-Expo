{
  "expo": {
    "name": "BukkaPay",
    "slug": "bukkapay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bukkapay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#001A72",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bukkapay.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "BukkaPay needs camera access to scan QR codes for payments."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "BukkaPay uses Face ID for quick and secure sign-in."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#001A72",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "backendUrl": "https://bukkapay-backend-production.up.railway.app",
      "router": {},
      "eas": {
        "projectId": "21571957-b3da-4766-ac08-ce2fa2170cb1"
      }
    }
  }
}